if ! command -v conda >/dev/null 2>&1; then
  echo "conda not found; create this environment with: conda env create -f environment.yml"
  exit 0
fi

eval "$(conda shell.bash hook)"

if ! conda env list | awk '{print $1}' | grep -qx "arrayscope"; then
  echo "conda environment 'arrayscope' not found; create it with: conda env create -f environment.yml"
  exit 0
fi

conda activate arrayscope
